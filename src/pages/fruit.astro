---
import ExperienceCard from "../components/ExperienceCard.astro";
import Layout from "../layouts/Layout.astro";
import { experiences } from "../data/experiences";
import { fruits } from "../data/fruits";
import { fruitSources } from "../data/sourcing";
import { rankedExperiences } from "../lib/rank";

const fruitExperiences = rankedExperiences(
  experiences.filter((item) => item.kind === "fruit" || item.kind === "farm"),
);
const signalLabel = {
  strong: "Strong July bet",
  possible: "Possible in July",
  "year-round": "Usually year-round",
};
const categoryLabel = {
  coffee: "Coffee · also a fruit",
  market: "Farmers market",
  "swap meet": "Swap meet",
  "farm stand": "Farm stand",
};
const categorySlug = {
  coffee: "coffee",
  market: "market",
  "swap meet": "swap",
  "farm stand": "stand",
};
const nearBase = fruitSources
  .filter((source) => source.corridor === "near-base")
  .sort((a, b) => a.driveFromBase - b.driveFromBase);
const onRoute = fruitSources
  .filter((source) => source.corridor === "airport-route")
  .sort((a, b) => b.driveFromBase - a.driveFromBase);
---

<Layout title="Fruit">
  <section class="page-head wrap fruit-head">
    <p class="eyebrow">Taste by cultivar, not category</p>
    <h1>Build a Maui fruit flight.</h1>
    <p>
      Buy from growers, ask what is ripe, and turn every piece into a small
      sensory experiment. Picking requires explicit permission.
    </p>
  </section>

  <section class="section wrap">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Freshest, closest, on the way in</p>
        <h2>Where to actually buy it</h2>
      </div>
    </div>
    <p class="source-lede">
      Two questions decide freshness: what is closest to Keawakapu, and what you
      can grab on the OGG→Kīhei drive without a detour. For raw produce nearest
      base, the <strong>South Maui Gardens Thursday market</strong> (10 min) and
      <strong>Farmers Market Maui</strong> on S. Kīhei Rd are in the ranked moves
      below. The stops here add same-road coffee and the markets worth catching on
      the way down from the airport.
    </p>

    <h3 class="source-group">Closest to base</h3>
    <div class="source-grid">
      {
        nearBase.map((source) => (
          <article class="source-card">
            <div class="source-chips">
              <span
                class:list={[
                  "source-tag",
                  `cat-${categorySlug[source.category]}`,
                ]}
              >
                {categoryLabel[source.category]}
              </span>
              <span class="source-distance">
                {source.driveFromBase} min from base
              </span>
            </div>
            <h4>{source.name}</h4>
            <p class="source-fresh">{source.freshPick}</p>
            <dl class="source-meta">
              <div>
                <dt>Where</dt>
                <dd>{source.routeNote}</dd>
              </div>
              <div>
                <dt>Open</dt>
                <dd>{source.openLabel}</dd>
              </div>
              <div>
                <dt>Trip fit</dt>
                <dd>{source.tripFit}</dd>
              </div>
            </dl>
            <div class="card-actions">
              <a
                class="button primary"
                href={source.mapUrl}
                target="_blank"
                rel="noreferrer"
              >
                Map
              </a>
              <a
                class="button secondary"
                href={source.sourceUrl}
                target="_blank"
                rel="noreferrer"
              >
                {source.sourceLabel}
              </a>
            </div>
          </article>
        ))
      }
    </div>

    <h3 class="source-group">On the drive from OGG</h3>
    <div class="source-grid">
      {
        onRoute.map((source) => (
          <article class="source-card">
            <div class="source-chips">
              <span
                class:list={[
                  "source-tag",
                  `cat-${categorySlug[source.category]}`,
                ]}
              >
                {categoryLabel[source.category]}
              </span>
              <span class="source-distance">
                {source.driveFromBase} min from base
              </span>
            </div>
            <h4>{source.name}</h4>
            <p class="source-fresh">{source.freshPick}</p>
            <dl class="source-meta">
              <div>
                <dt>Where</dt>
                <dd>{source.routeNote}</dd>
              </div>
              <div>
                <dt>Open</dt>
                <dd>{source.openLabel}</dd>
              </div>
              <div>
                <dt>Trip fit</dt>
                <dd>{source.tripFit}</dd>
              </div>
            </dl>
            <div class="card-actions">
              <a
                class="button primary"
                href={source.mapUrl}
                target="_blank"
                rel="noreferrer"
              >
                Map
              </a>
              <a
                class="button secondary"
                href={source.sourceUrl}
                target="_blank"
                rel="noreferrer"
              >
                {source.sourceLabel}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section wrap">
    <div class="fruit-grid">
      {
        fruits.map((fruit) => (
          <article class="fruit-card">
            <span class:list={["season-signal", `signal-${fruit.julySignal}`]}>
              {signalLabel[fruit.julySignal]}
            </span>
            <h2>{fruit.name}</h2>
            <dl>
              <div>
                <dt>Look for</dt>
                <dd>{fruit.lookFor}</dd>
              </div>
              <div>
                <dt>Taste</dt>
                <dd>{fruit.taste}</dd>
              </div>
              <div>
                <dt>Ask</dt>
                <dd>“{fruit.question}”</dd>
              </div>
            </dl>
          </article>
        ))
      }
    </div>
  </section>

  <section class="permission-band">
    <div class="wrap">
      <p class="eyebrow">No casual U-pick assumption</p>
      <h2>Fruit on a tree is not automatic permission.</h2>
      <p>
        Do not pick from roadsides, parks, reserves, private yards, or farms
        without a direct yes. ONO's reserved tour explicitly includes guided
        picking; ordinary market visits do not.
      </p>
    </div>
  </section>

  <section class="section wrap">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Where to start</p>
        <h2>Ranked fruit moves</h2>
      </div>
    </div>
    <div class="card-grid">
      {
        fruitExperiences.map((experience) => (
          <ExperienceCard experience={experience} />
        ))
      }
    </div>
  </section>
</Layout>
