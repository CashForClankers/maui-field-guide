---
import Layout from "../layouts/Layout.astro";
import { animalSupplyStores } from "../data/animalSupplies";
import { creaturePlaces, creatures } from "../data/creatures";
import { creatureSightings, sightingsGeneratedAt } from "../data/sightings";
import { basePath } from "../lib/paths";
import { rankedCreaturePlaces } from "../lib/rank";

const getSighting = (id: string) =>
  creatureSightings.find((item) => item.creatureId === id);

const sightingDateLabel = (iso: string) =>
  new Date(`${iso}T12:00:00Z`).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });

const getCreature = (id: string) => {
  const creature = creatures.find((item) => item.id === id);
  if (!creature) throw new Error(`Missing featured creature: ${id}`);
  return creature;
};
const featured = [
  getCreature("honu"),
  getCreature("spinner-dolphin"),
  getCreature("wedge-tailed-shearwater"),
] as const;

const habitatFilters = [
  ["all", "All"],
  ["reef", "Reef"],
  ["open ocean", "Open ocean"],
  ["shoreline", "Shoreline"],
  ["wetland", "Wetland"],
  ["resort grounds", "Resort & dusk"],
] as const;

const typeFilters = [
  ["all", "Everything"],
  ["fish", "Fish"],
  ["small-ocean", "Coral & invertebrates"],
  ["large-ocean", "Large ocean life"],
  ["land-air", "Birds & land life"],
] as const;

const creatureGroup = (kind: (typeof creatures)[number]["kind"]) => {
  if (kind === "reef fish") return "fish";
  if (["echinoderm", "cephalopod", "coral"].includes(kind))
    return "small-ocean";
  if (["ray", "shark", "marine mammal", "sea turtle"].includes(kind))
    return "large-ocean";
  return "land-air";
};

const getCreaturePlaces = (creatureId: string) =>
  rankedCreaturePlaces(
    creaturePlaces.filter((place) => place.creatureId === creatureId),
  );
---

<Layout
  title="Creature field guide"
  description="A kid-readable Maui wildlife guide with real photos, science notes, ethical viewing distances, and places to look beyond Mana Kai."
>
  <section class="creature-hero wrap">
    <div>
      <p class="eyebrow">{creatures.length} living field marks</p>
      <h1>Know what you’re looking at.</h1>
      <p>
        Real photos, small science, and ethical places to look beyond Mana Kai.
        Every animal now has ranked exact pins, parking notes, and live
        community sighting counts from iNaturalist. These are possibilities—not
        animals owed to us by the island.
      </p>
    </div>
    <div class="creature-collage" aria-label="Featured Maui wildlife">
      <img
        src={`${basePath}${featured[0].image}`}
        alt={featured[0].imageAlt}
        width="750"
        height="500"
      />
      <img
        src={`${basePath}${featured[1].image}`}
        alt={featured[1].imageAlt}
        width="960"
        height="642"
      />
      <img
        src={`${basePath}${featured[2].image}`}
        alt={featured[2].imageAlt}
        width="650"
        height="433"
      />
    </div>
  </section>

  <section class="creature-intro">
    <div class="wrap creature-intro-inner">
      <strong>Field method</strong>
      <p>Stop moving → notice shape and behavior → name it → give it space.</p>
      <a href={`${basePath}rules/`}>Check every distance rule →</a>
    </div>
  </section>

  <section class="filter-shell wrap" aria-label="Wildlife filters">
    <label class="search-box">
      <span class="sr-only">Search wildlife</span>
      <input
        id="creature-search"
        type="search"
        placeholder="Search dolphin, reef, dusk…"
        autocomplete="off"
      />
    </label>
    <div
      class="filter-row"
      role="group"
      aria-label="Filter wildlife by habitat"
    >
      {
        habitatFilters.map(([value, label], index) => (
          <button
            class:list={["filter-chip", { active: index === 0 }]}
            data-filter={value}
            type="button"
            aria-pressed={index === 0 ? "true" : "false"}
          >
            {label}
          </button>
        ))
      }
    </div>
    <div
      class="filter-row creature-type-row"
      role="group"
      aria-label="Filter wildlife by type"
    >
      {
        typeFilters.map(([value, label], index) => (
          <button
            class:list={[
              "filter-chip",
              "filter-chip-secondary",
              { active: index === 0 },
            ]}
            data-group-filter={value}
            type="button"
            aria-pressed={index === 0 ? "true" : "false"}
          >
            {label}
          </button>
        ))
      }
    </div>
    <div class="creature-directory-tools">
      <p id="creature-result-count" class="result-count" aria-live="polite">
        {creatures.length} animals
      </p>
      <div>
        <button id="expand-creatures" class="text-button" type="button"
          >Expand visible</button
        >
        <button id="collapse-creatures" class="text-button" type="button"
          >Collapse all</button
        >
      </div>
    </div>
  </section>

  <section class="section wrap creature-grid" id="creature-grid">
    {
      creatures.map((creature, index) => (
        <article
          class="creature-card"
          id={creature.id}
          data-card
          data-habitat={creature.habitat}
          data-group={creatureGroup(creature.kind)}
          data-search={`${creature.commonName} ${creature.hawaiianName ?? ""} ${creature.scientificName} ${creature.kind} ${creature.habitat} ${creature.recognition}`.toLowerCase()}
        >
          <div class="creature-glance">
            {creature.image ? (
              <figure class="creature-photo">
                <img
                  src={`${basePath}${creature.image}`}
                  alt={creature.imageAlt ?? creature.commonName}
                  width="960"
                  height="640"
                  loading={index < 4 ? "eager" : "lazy"}
                  decoding="async"
                />
                <figcaption>
                  {creature.photoCredit} · {creature.photoLicense}
                </figcaption>
              </figure>
            ) : (
              <div
                class="creature-photo creature-photo-placeholder"
                role="img"
                aria-label={`No field photo yet for ${creature.commonName}`}
              >
                <span>{creature.kind}</span>
                <strong>{creature.commonName.slice(0, 1)}</strong>
                <small>Field mark card</small>
              </div>
            )}
            <div class="creature-copy">
              <div class="creature-topline">
                <span>{creature.kind}</span>
                <span>
                  {creature.driveMinutes === 0
                    ? "On site"
                    : `≈ ${creature.driveMinutes} min`}
                </span>
              </div>
              {creature.hawaiianName && (
                <p class="creature-hawaiian">{creature.hawaiianName}</p>
              )}
              <h2>{creature.commonName}</h2>
              <p class="scientific-name">{creature.scientificName}</p>
              <div class="creature-quick-id">
                <span>Quick ID</span>
                <p>{creature.recognition}</p>
              </div>
            </div>
          </div>
          <details class="creature-details">
            <summary>
              <span>Learn, map & safety</span>
              <span aria-hidden="true">+</span>
            </summary>
            <div class="creature-details-body">
              <dl class="creature-notes">
                <div>
                  <>
                    <dt>Small science</dt>
                    <dd>{creature.scienceNote}</dd>
                  </>
                </div>
                <div class="kid-mission">
                  <>
                    <dt>Kid field mission</dt>
                    <dd>{creature.kidMission}</dd>
                  </>
                </div>
                <div>
                  <>
                    <dt>Where to look</dt>
                    <dd>{creature.whereToLook}</dd>
                  </>
                </div>
                <div class="safety-note">
                  <>
                    <dt>Give it room</dt>
                    <dd>{creature.safety}</dd>
                  </>
                </div>
              </dl>
              {(() => {
                const sighting = getSighting(creature.id);
                if (!sighting || sighting.recentObservations === 0) return null;
                return (
                  <p class="creature-sighting-fact">
                    <span class="creature-sighting-badge">
                      Community-documented
                    </span>{" "}
                    {sighting.recentObservations} research-grade iNaturalist{" "}
                    {sighting.recentObservations === 1
                      ? "sighting"
                      : "sightings"}{" "}
                    within ~30 miles of Mana Kai in the past year
                    {sighting.mostRecentDate && (
                      <>
                        , most recent{" "}
                        {sightingDateLabel(sighting.mostRecentDate)}
                        {sighting.mostRecentPlaceGuess &&
                          ` near ${sighting.mostRecentPlaceGuess}`}
                      </>
                    )}
                    . Not a promise of what you’ll see today.
                    {sighting.observationUrl && (
                      <>
                        {" "}
                        <a
                          href={sighting.observationUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          See the observation →
                        </a>
                      </>
                    )}
                  </p>
                );
              })()}
              <section
                class="creature-places"
                aria-labelledby={`${creature.id}-places-title`}
              >
                <div class="creature-places-head">
                  <div>
                    <>
                      <p class="eyebrow">Closest field maps</p>
                      <h3 id={`${creature.id}-places-title`}>
                        Nearest places to try
                      </h3>
                    </>
                  </div>
                  <p>Sorted from Mana Kai by drive, then evidence.</p>
                </div>
                <ol>
                  {getCreaturePlaces(creature.id).map((place, placeIndex) => (
                    <li class="creature-place">
                      <a
                        class="creature-place-map"
                        href={place.mapUrl}
                        target="_blank"
                        rel="noreferrer"
                        aria-label={`Open map for ranked place ${placeIndex + 1}: ${place.name}`}
                      >
                        <span class="creature-place-pin" aria-hidden="true">
                          {placeIndex + 1}
                        </span>
                        <span>Open exact pin</span>
                        {place.coordinates && (
                          <small>{place.coordinates}</small>
                        )}
                      </a>
                      <div class="creature-place-copy">
                        <div class="creature-place-title">
                          <div>
                            <span>#{placeIndex + 1}</span>
                            <h4>{place.name}</h4>
                          </div>
                          <span
                            class={`evidence evidence-${place.evidence.replaceAll(" ", "-")}`}
                          >
                            {place.evidence}
                          </span>
                        </div>
                        <p>{place.reason}</p>
                        <dl>
                          <div>
                            <dt>Drive</dt>
                            <dd>
                              {place.driveMinutes === 0
                                ? "Walk / on site"
                                : `≈ ${place.driveMinutes} min`}
                            </dd>
                          </div>
                          <div>
                            <dt>Park / enter</dt>
                            <dd>{place.parking}</dd>
                          </div>
                          <div>
                            <dt>Best try</dt>
                            <dd>{place.timing}</dd>
                          </div>
                        </dl>
                        <p class="creature-place-caveat">{place.caveat}</p>
                        <a
                          class="creature-place-source"
                          href={place.sourceUrl}
                          target="_blank"
                          rel="noreferrer"
                        >
                          Access evidence · {place.sourceLabel}
                        </a>
                      </div>
                    </li>
                  ))}
                </ol>
              </section>
              <div class="creature-actions">
                <a
                  class="button primary"
                  href={
                    getCreaturePlaces(creature.id)[0]?.mapUrl ?? creature.mapUrl
                  }
                  target="_blank"
                  rel="noreferrer"
                >
                  Open #1 map
                </a>
                <a
                  class="button secondary"
                  href={creature.sourceUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  Read the science
                </a>
              </div>
              {creature.photoSourceUrl && (
                <a
                  class="photo-source"
                  href={creature.photoSourceUrl}
                  target="_blank"
                  rel="noreferrer"
                >
                  Photo source and license
                </a>
              )}
            </div>
          </details>
        </article>
      ))
    }
    <p id="creature-empty-state" class="empty-state" hidden>
      No animal matches that filter. Clear the search or pick a wider habitat.
    </p>
  </section>

  <section class="section wrap">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Not wild — ordinary retail, no appointment</p>
        <h2>Where to see (or buy feed for) baby chicks and barnyard animals</h2>
      </div>
    </div>
    <p class="source-lede">
      These are working Kahului feed stores, not attractions or sanctuaries.
      They regularly stock live chicks, ducklings, and rabbits alongside feed
      and coops — a low-friction way to see baby farm animals up close on a
      supply run. Hours are third-party aggregated, so call ahead.
    </p>
    <div class="source-grid">
      {
        animalSupplyStores.map((store) => (
          <article class="source-card">
            <div class="source-chips">
              <span class="source-distance">
                ≈ {store.driveMinutes} min from base
              </span>
            </div>
            <h4>{store.name}</h4>
            <p class="source-fresh">{store.whatFor}</p>
            <dl class="source-meta">
              <div>
                <dt>Where</dt>
                <dd>{store.address}</dd>
              </div>
              <div>
                <dt>Hours</dt>
                <dd>{store.hoursLabel}</dd>
              </div>
            </dl>
            <div class="card-actions">
              <a
                class="button primary"
                href={store.mapUrl}
                target="_blank"
                rel="noreferrer"
              >
                Map
              </a>
              <a
                class="button secondary"
                href={store.sourceUrl}
                target="_blank"
                rel="noreferrer"
              >
                {store.sourceLabel}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="source-panel wrap">
    <p>
      Science and access checked against NOAA Fisheries, Hawaiʻi DLNR, Maui
      County, NOAA Ocean Service, Hawaiʻi Sea Grant, and the U.S. Fish &
      Wildlife Service on July 5, 2026. Coordinates are map pins, not wildlife
      locations. Conditions and sightings are never guaranteed. Community
      sighting counts pulled from the public iNaturalist API (research-grade,
      non-captive records within 50km of Mana Kai) on {sightingsGeneratedAt};
      credit to the volunteer naturalists who logged each observation.
    </p>
    <a class="button primary" href={`${basePath}discover/`}>Plan one stop</a>
  </section>

  <script>
    const search = document.querySelector<HTMLInputElement>("#creature-search");
    const chips = [
      ...document.querySelectorAll<HTMLButtonElement>("[data-filter]"),
    ];
    const groupChips = [
      ...document.querySelectorAll<HTMLButtonElement>("[data-group-filter]"),
    ];
    const cards = [...document.querySelectorAll<HTMLElement>("[data-card]")];
    const count = document.querySelector<HTMLElement>("#creature-result-count");
    const empty = document.querySelector<HTMLElement>("#creature-empty-state");
    const expand =
      document.querySelector<HTMLButtonElement>("#expand-creatures");
    const collapse = document.querySelector<HTMLButtonElement>(
      "#collapse-creatures",
    );
    let activeFilter = "all";
    let activeGroup = "all";

    function render() {
      const query = search?.value.trim().toLowerCase() ?? "";
      let visible = 0;
      for (const card of cards) {
        const matchesText =
          !query || (card.dataset.search ?? "").includes(query);
        const matchesFilter =
          activeFilter === "all" || card.dataset.habitat === activeFilter;
        const matchesGroup =
          activeGroup === "all" || card.dataset.group === activeGroup;
        const show = matchesText && matchesFilter && matchesGroup;
        card.hidden = !show;
        if (!show) card.querySelector("details")?.removeAttribute("open");
        if (show) visible += 1;
      }
      if (count)
        count.textContent = `${visible} animal${visible === 1 ? "" : "s"}`;
      if (empty) empty.hidden = visible !== 0;
    }

    search?.addEventListener("input", render);
    for (const chip of chips) {
      chip.addEventListener("click", () => {
        activeFilter = chip.dataset.filter ?? "all";
        for (const candidate of chips)
          candidate.classList.toggle("active", candidate === chip);
        for (const candidate of chips)
          candidate.setAttribute("aria-pressed", String(candidate === chip));
        render();
      });
    }
    for (const chip of groupChips) {
      chip.addEventListener("click", () => {
        activeGroup = chip.dataset.groupFilter ?? "all";
        for (const candidate of groupChips)
          candidate.classList.toggle("active", candidate === chip);
        for (const candidate of groupChips)
          candidate.setAttribute("aria-pressed", String(candidate === chip));
        render();
      });
    }
    expand?.addEventListener("click", () => {
      for (const card of cards) {
        if (!card.hidden)
          card.querySelector("details")?.setAttribute("open", "");
      }
    });
    collapse?.addEventListener("click", () => {
      for (const card of cards)
        card.querySelector("details")?.removeAttribute("open");
    });
  </script>
</Layout>
